--!strict

local protocol = {}

-- this read is the authority after a datastore write returns an unknown result.
local function read_current(transaction_id: string, ops: any)
	local current, read_error = ops.get_consistent(transaction_id)
	if current == nil then
		return nil, read_error or "decision_unknown"
	end
	return current, nil
end

local function renew_or_resolve(transaction: any, ops: any): (any?, string?)
	if transaction.state == "completed" or transaction.state == "aborted" then
		return transaction, nil
	end
	local renewed, renew_error = ops.renew(transaction.id)
	if renewed ~= nil then
		return renewed, nil
	end
	local current, read_error = read_current(transaction.id, ops)
	if current == nil then
		return nil, read_error or renew_error
	end
	if current.state ~= "completed" and current.state ~= "aborted" and not ops.matches_fence(current) then
		return nil, "coordinator_fenced"
	end
	return current, nil
end

local function drive_commit(transaction: any, ops: any)
	if transaction.state == "completed" then
		for _, user_id in ipairs(transaction.users) do
			local finalized, finalize_error = ops.finalize(user_id, transaction.id)
			if not finalized then
				return false, finalize_error or "finalize_incomplete"
			end
		end
		ops.unindex(transaction.id)
		return true, transaction
	end
	if transaction.state ~= "committing" then
		return false, "commit_not_decided"
	end

	-- committing is irreversible; recovery may only replay these idempotent postimages.
	for _, user_id in ipairs(transaction.users) do
		local current, renew_error = renew_or_resolve(transaction, ops)
		if current == nil then
			return false, renew_error
		end
		if current.state == "completed" then
			return drive_commit(current, ops)
		end
		if current.state ~= "committing" then
			return false, "commit_state_changed"
		end
		transaction = current

		local applied, apply_error = ops.apply(user_id, transaction)
		if not applied then
			return false, apply_error or "apply_incomplete"
		end
	end

	local completed, complete_error = ops.transition(transaction.id, "completed")
	if completed ~= nil then
		return drive_commit(completed, ops)
	end
	local current, read_error = read_current(transaction.id, ops)
	if current ~= nil and current.state == "completed" then
		return drive_commit(current, ops)
	end
	return false, read_error or complete_error or "completion_unknown"
end

local function drive_abort(transaction: any, ops: any)
	-- a worker can discover a newer commit decision while it is trying to abort.
	if transaction.state == "completed" or transaction.state == "committing" then
		return drive_commit(transaction, ops)
	end

	if transaction.state == "preparing" then
		local aborting, decision_error = ops.transition(transaction.id, "aborting")
		if aborting == nil then
			local current, read_error = read_current(transaction.id, ops)
			if current == nil then
				return false, read_error or decision_error or "abort_decision_unknown"
			end
			transaction = current
		else
			transaction = aborting
		end
	end

	if transaction.state == "committing" or transaction.state == "completed" then
		return drive_commit(transaction, ops)
	end
	if transaction.state ~= "aborting" and transaction.state ~= "aborted" then
		return false, "invalid_abort_state"
	end

	for _, user_id in ipairs(transaction.users) do
		if transaction.state == "aborting" then
			local current, renew_error = renew_or_resolve(transaction, ops)
			if current == nil then
				return false, renew_error
			end
			if current.state == "committing" or current.state == "completed" then
				return drive_commit(current, ops)
			end
			if current.state ~= "aborting" and current.state ~= "aborted" then
				return false, "abort_state_changed"
			end
			transaction = current
		end
		local rolled_back, rollback_error = ops.rollback(user_id, transaction.id)
		if not rolled_back then
			return false, rollback_error or "rollback_incomplete"
		end
	end
	if transaction.state == "aborted" then
		ops.unindex(transaction.id)
		return true, transaction
	end

	local aborted, complete_error = ops.transition(transaction.id, "aborted")
	if aborted ~= nil then
		ops.unindex(transaction.id)
		return true, aborted
	end
	local current, read_error = read_current(transaction.id, ops)
	if current ~= nil and current.state == "aborted" then
		ops.unindex(transaction.id)
		return true, current
	end
	return false, read_error or complete_error or "abort_completion_unknown"
end

function protocol.execute(transaction: any, ops: any)
	local created, create_result = ops.create(transaction)
	if not created then
		return false, create_result
	end
	transaction = create_result

	for _, user_id in ipairs(transaction.users) do
		local current, renew_error = renew_or_resolve(transaction, ops)
		if current == nil then
			return false, renew_error
		end
		if current.state ~= "preparing" then
			return protocol.recover(current, ops)
		end
		transaction = current

		local prepared, prepare_error = ops.prepare(user_id, transaction)
		if not prepared then
			local resolved, outcome = drive_abort(transaction, ops)
			if resolved and outcome.state == "completed" then
				return true, outcome
			end
			return false, resolved and prepare_error or outcome
		end
	end

	-- persist the decision before either inventory receives the other side's items.
	local committing, decision_error = ops.transition(transaction.id, "committing")
	if committing == nil then
		local current, read_error = read_current(transaction.id, ops)
		if current == nil then
			return false, read_error or decision_error or "commit_decision_unknown"
		end
		if current.state == "preparing" or current.state == "aborting" or current.state == "aborted" then
			local resolved, outcome = drive_abort(current, ops)
			if resolved and outcome.state == "completed" then
				return true, outcome
			end
			return false, resolved and decision_error or outcome
		end
		committing = current
	end
	return drive_commit(committing, ops)
end

function protocol.recover(transaction: any, ops: any)
	if transaction.state == "completed" then
		return drive_commit(transaction, ops)
	end
	if transaction.state == "committing" then
		return drive_commit(transaction, ops)
	end
	if transaction.state == "preparing" or transaction.state == "aborting" or transaction.state == "aborted" then
		return drive_abort(transaction, ops)
	end
	return false, "invalid_recovery_state"
end

return table.freeze(protocol)
