	expect_request_rejected(wrong_sequence, "invalid_bootstrap")

	local unknown_action = {
		version = config.protocol_version,
		session = "bootstrap_session",
		sequence = 0,
		request_id = "request_00000002",
		action = "admin_grant",
		payload = {},
	}
	expect_request_rejected(unknown_action, "invalid_action")
end

