local function expect(condition: boolean, message: string)
	if not condition then
		error(message, 2)
	end
end

local function expect_equal(actual: any, expected: any, message: string)
	if actual ~= expected then
		error(string.format("%s; expected=%s actual=%s", message, tostring(expected), tostring(actual)), 2)
	end
end

local function new_item(item_id: string)
	return {
		id = item_id,
		kind = "verification_item",
		name = "verification item",
		tradable = true,
		metadata = {},
		created_at = 1,
	}
end

local function new_transaction(options: any?): any
	local values = options or {}
	local state = values.state or "preparing"
	local left_outgoing = values.left_outgoing
	local right_outgoing = values.right_outgoing
	if left_outgoing == nil then
		left_outgoing = { new_item("item_00000000000000000000000000000001") }
	end
	if right_outgoing == nil then
		right_outgoing = { new_item("item_00000000000000000000000000000002") }
	end

	local updated_at = 1
	local terminal_at: number? = nil
	if state == "completed" or state == "aborted" then
		updated_at = 2
		terminal_at = 2
	end

	return {
		schema_version = config.transaction_schema_version,
		protocol_revision = config.protocol_revision,
		id = transaction_id,
		state = state,
		users = { left_user_id, right_user_id },
		outgoing = {
			[tostring(left_user_id)] = left_outgoing,
			[tostring(right_user_id)] = right_outgoing,
		},
		created_at = 1,
		updated_at = updated_at,
		server_id = "verification_server",
		coordinator = {
			owner = "verification_server",
			token = "coordinator_test_token_0001",
			epoch = 1,
			expires_at = 600,
		},
		progress = {
			prepared = {},
			applied = {},
			recovery_count = 0,
			last_error = "",
		},
		terminal_at = terminal_at,
	}
end

local function append_call(model: any, name: string)
	table.insert(model.calls, name)
end

local function increment(map: { [string]: number }, key: string)
	map[key] = (map[key] or 0) + 1
end

local function count_for(map: { [string]: number }, key: string): number
	return map[key] or 0
end

local function transition_allowed(current_state: string, next_state: string): boolean
	if current_state == next_state then
		return true
	end
	if current_state == "preparing" then
		return next_state == "aborting" or next_state == "committing"
	elseif current_state == "aborting" then
		return next_state == "aborted"
	elseif current_state == "committing" then
		return next_state == "completed"
	end
	return false
end

local function new_protocol_model(options: any?)
	local settings = options or {}
	local model: any = {
		transaction = settings.transaction or new_transaction(),
		calls = {},
		prepare_calls = {},
		rollback_calls = {},
		apply_calls = {},
		finalize_calls = {},
		application_effects = {},
		application_effect_counts = {},
		consistent_reads = 0,
		renewals = 0,
		unindex_calls = 0,
	}
	for _, user_id in ipairs(settings.initially_applied_user_ids or {}) do
		local key = tostring(user_id)
		model.application_effects[key] = true
		model.application_effect_counts[key] = 1
	end

	local ops: any = {}

	function ops.create(candidate: any)
		append_call(model, "create")
		model.transaction = candidate
		return true, model.transaction
	end

	function ops.renew(_: string): (any?, string?)
		append_call(model, "renew")
		model.renewals += 1
		if settings.renew_failure then
			return nil, "injected_renew_failure"
		end
		return model.transaction, nil
	end

	function ops.get_consistent(_: string): (any?, string?)
		append_call(model, "get_consistent")
		model.consistent_reads += 1
		if settings.consistent_read_unknown then
			return nil, "injected_consistent_read_failure"
		end
		return model.transaction, nil
	end

	function ops.matches_fence(_: any): boolean
		return settings.fence_lost ~= true
	end

	function ops.prepare(user_id: number, _: any): (boolean, string?)
		local key = tostring(user_id)
		append_call(model, "prepare:" .. key)
		increment(model.prepare_calls, key)
		if settings.fail_prepare_user_id == user_id then
			return false, "injected_prepare_failure"
		end
		return true, nil
	end

	function ops.rollback(user_id: number, _: string): (boolean, string?)
		local key = tostring(user_id)
		append_call(model, "rollback:" .. key)
		increment(model.rollback_calls, key)
		return true, nil
	end

	function ops.apply(user_id: number, _: any): (boolean, string?)
		local key = tostring(user_id)
		append_call(model, "apply:" .. key)
		increment(model.apply_calls, key)
		if settings.fail_apply_user_id == user_id then
			return false, "injected_apply_failure"
		end
		if model.application_effects[key] ~= true then
			model.application_effects[key] = true
			model.application_effect_counts[key] = 1
		end
		return true, nil
	end

	function ops.finalize(user_id: number, _: string): (boolean, string?)
		local key = tostring(user_id)
		append_call(model, "finalize:" .. key)
		increment(model.finalize_calls, key)
		return true, nil
	end

	function ops.transition(_: string, next_state: string): (any?, string?)
		append_call(model, "transition:" .. next_state)
		local current_state = model.transaction.state
		if not transition_allowed(current_state, next_state) then
			return nil, "invalid_transition"
		end

		if next_state == "committing" and settings.commit_decision_unknown then
			return nil, "injected_commit_decision_failure"
		end

		model.transaction.state = next_state
		model.transaction.updated_at += 1
		if next_state == "completed" or next_state == "aborted" then
			model.transaction.terminal_at = model.transaction.updated_at
		end

		if next_state == "committing" and settings.commit_acknowledgement_ambiguous then
			return nil, "injected_ambiguous_commit_acknowledgement"
		end
		return model.transaction
	end

	function ops.mark_progress(_: string, section: string, user_id: number)
		local key = tostring(user_id)
		append_call(model, "progress:" .. section .. ":" .. key)
		model.transaction.progress[section][key] = true
		return true
	end

	function ops.unindex(_: string)
		append_call(model, "unindex")
		model.unindex_calls += 1
		return true
	end

	return model, ops
end

local function expect_no_calls(map: { [string]: number }, message: string)
	for _, count in pairs(map) do
		if count > 0 then
			error(message, 2)
		end
	end
end

local function protocol_execute_completes_and_finalizes()
	local model, ops = new_protocol_model()
	local ok, result = protocol.execute(model.transaction, ops)
	expect(ok, tostring(result))
	expect_equal(model.transaction.state, "completed", "successful execution did not complete")
	expect_equal(count_for(model.prepare_calls, tostring(left_user_id)), 1, "left side was not prepared once")
	expect_equal(count_for(model.prepare_calls, tostring(right_user_id)), 1, "right side was not prepared once")
	expect_equal(count_for(model.apply_calls, tostring(left_user_id)), 1, "left side was not applied once")
	expect_equal(count_for(model.apply_calls, tostring(right_user_id)), 1, "right side was not applied once")
	expect_equal(count_for(model.finalize_calls, tostring(left_user_id)), 1, "left side was not finalized once")
	expect_equal(count_for(model.finalize_calls, tostring(right_user_id)), 1, "right side was not finalized once")
	expect_equal(model.unindex_calls, 1, "completed transaction was not unindexed")
	expect_no_calls(model.rollback_calls, "successful transaction rolled back an inventory")
end

local function protocol_prepare_failure_decides_abort_before_rollback()
	local model, ops = new_protocol_model({ fail_prepare_user_id = right_user_id })
	local ok = protocol.execute(model.transaction, ops)
	expect(not ok, "injected prepare failure unexpectedly completed")
	expect_equal(model.transaction.state, "aborted", "prepare failure did not reach aborted")

	local abort_decided = false
	for _, call_name in ipairs(model.calls) do
		if call_name == "transition:aborting" then
			abort_decided = true
		elseif string.sub(call_name, 1, 9) == "rollback:" then
			expect(abort_decided, "rollback ran before the durable abort decision")
		end
	end
	expect(abort_decided, "prepare failure did not record an abort decision")
	expect_equal(count_for(model.rollback_calls, tostring(left_user_id)), 1, "left side was not rolled back")
	expect_equal(count_for(model.rollback_calls, tostring(right_user_id)), 1, "right side was not rolled back idempotently")
	expect_no_calls(model.apply_calls, "aborted transaction applied an inventory")
	expect_equal(model.unindex_calls, 1, "aborted transaction was not unindexed")
end

local function protocol_ambiguous_commit_readback_rolls_forward()
	local model, ops = new_protocol_model({ commit_acknowledgement_ambiguous = true })
	local ok, result = protocol.execute(model.transaction, ops)
	expect(ok, tostring(result))
	expect_equal(model.consistent_reads, 1, "ambiguous commit was not resolved by a consistent read")
	expect_equal(model.transaction.state, "completed", "acknowledged commit did not roll forward")
	expect_equal(count_for(model.apply_calls, tostring(left_user_id)), 1, "left side did not roll forward")
	expect_equal(count_for(model.apply_calls, tostring(right_user_id)), 1, "right side did not roll forward")
	expect_no_calls(model.rollback_calls, "acknowledged commit was rolled back")
end

local function protocol_unknown_commit_decision_never_rolls_back()
	local model, ops = new_protocol_model({
		commit_decision_unknown = true,
		consistent_read_unknown = true,
	})
	local ok, result = protocol.execute(model.transaction, ops)
	expect(not ok, "unknown commit decision unexpectedly completed")
	expect_equal(result, "injected_consistent_read_failure", "unknown decision returned the wrong failure")
	expect_equal(model.transaction.state, "preparing", "unknown decision changed transaction state")
	expect_equal(model.consistent_reads, 1, "unknown decision was not checked consistently")
	expect_no_calls(model.rollback_calls, "unknown commit decision triggered rollback")
	expect_no_calls(model.apply_calls, "unknown commit decision applied inventory")
	expect_equal(model.unindex_calls, 0, "unknown transaction was removed from recovery discovery")
end

local function protocol_recover_preparing_aborts()
	local transaction = new_transaction({ state = "preparing" })
	transaction.progress.prepared[tostring(left_user_id)] = true
	local model, ops = new_protocol_model({ transaction = transaction })
	local ok, result = protocol.recover(model.transaction, ops)
	expect(ok, tostring(result))
	expect_equal(model.transaction.state, "aborted", "preparing recovery did not abort")
	expect_equal(count_for(model.rollback_calls, tostring(left_user_id)), 1, "prepared side was not rolled back")
	expect_equal(count_for(model.rollback_calls, tostring(right_user_id)), 1, "unprepared side was not reconciled idempotently")
	expect_no_calls(model.apply_calls, "preparing recovery applied inventory")
end

local function protocol_recover_committing_reapplies_idempotently()
	local transaction = new_transaction({ state = "committing" })
	transaction.progress.applied[tostring(left_user_id)] = true
	transaction.progress.applied[tostring(right_user_id)] = true
	local model, ops = new_protocol_model({
		transaction = transaction,
		initially_applied_user_ids = { left_user_id },
	})
	local ok, result = protocol.recover(model.transaction, ops)
	expect(ok, tostring(result))
	expect_equal(model.transaction.state, "completed", "committing recovery did not complete")
	expect_equal(count_for(model.apply_calls, tostring(left_user_id)), 1, "left receipt was not rechecked")
	expect_equal(count_for(model.apply_calls, tostring(right_user_id)), 1, "right receipt was not rechecked")
	expect(model.application_effects[tostring(left_user_id)] == true, "left idempotent effect was lost")
	expect(model.application_effects[tostring(right_user_id)] == true, "right effect was not applied")
	expect_equal(
		model.application_effect_counts[tostring(left_user_id)],
		1,
		"left idempotent apply duplicated its effect"
	)
	expect_equal(
		model.application_effect_counts[tostring(right_user_id)],
		1,
		"right apply produced the wrong effect count"
	)
	expect_no_calls(model.rollback_calls, "committing recovery attempted rollback")
end

local function protocol_recover_completed_finalizes()
	local transaction = new_transaction({ state = "completed" })
	local model, ops = new_protocol_model({ transaction = transaction })
	local ok, result = protocol.recover(model.transaction, ops)
	expect(ok, tostring(result))
	expect_equal(count_for(model.finalize_calls, tostring(left_user_id)), 1, "left completed side was not finalized")
	expect_equal(count_for(model.finalize_calls, tostring(right_user_id)), 1, "right completed side was not finalized")
	expect_no_calls(model.apply_calls, "completed recovery reapplied inventory")
	expect_no_calls(model.rollback_calls, "completed recovery rolled back inventory")
	expect_equal(model.unindex_calls, 1, "completed recovery did not unindex")
end

local function protocol_apply_failure_stays_committing()
	local model, ops = new_protocol_model({ fail_apply_user_id = right_user_id })
	local ok, result = protocol.execute(model.transaction, ops)
	expect(not ok, "injected apply failure unexpectedly completed")
	expect_equal(result, "injected_apply_failure", "apply failure returned the wrong error")
	expect_equal(model.transaction.state, "committing", "apply failure lost the commit decision")
	expect_equal(count_for(model.apply_calls, tostring(left_user_id)), 1, "left apply did not run")
	expect_equal(count_for(model.apply_calls, tostring(right_user_id)), 1, "right apply was not attempted")
	expect_no_calls(model.rollback_calls, "committing transaction rolled back after apply failure")
	expect_no_calls(model.finalize_calls, "incomplete commit was finalized")
	expect_equal(model.unindex_calls, 0, "incomplete commit was removed from recovery discovery")
end

local function protocol_fence_loss_stops_before_participant_effects()
	local model, ops = new_protocol_model({ renew_failure = true, fence_lost = true })
	local ok, result = protocol.execute(model.transaction, ops)
	expect(not ok, "fenced coordinator unexpectedly continued")
	expect_equal(result, "coordinator_fenced", "fence loss returned the wrong error")
	expect_no_calls(model.prepare_calls, "fenced coordinator prepared an inventory")
	expect_no_calls(model.apply_calls, "fenced coordinator applied an inventory")
	expect_no_calls(model.rollback_calls, "fenced coordinator rolled back an inventory")
end

local function transaction_schema_accepts_valid_transaction()
	local transaction = new_transaction()
	local normalized, reason = schema.normalize_transaction(transaction, transaction.id)
	expect(normalized ~= nil, reason or "valid transaction was rejected")
	expect_equal(normalized.state, "preparing", "valid transaction state changed")
	expect_equal(#normalized.outgoing[tostring(left_user_id)], 1, "left items were not retained")
	expect_equal(#normalized.outgoing[tostring(right_user_id)], 1, "right items were not retained")
end

local function transaction_schema_rejects_empty_transaction()
	local transaction = new_transaction({ left_outgoing = {}, right_outgoing = {} })
