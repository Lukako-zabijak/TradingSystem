local function new_inventory_record(item_count: number)
	local record: any = { items = {} }
	for index = 1, item_count do
		local item = new_item(string.format("owned_%04d", index))
		record.items[item.id] = item
	end
	return record
end

local function transfer_allows_growth_from_499_to_500()
	local incoming = new_item("item_incoming_capacity_boundary")
	local transaction = new_transaction({ left_outgoing = {}, right_outgoing = { incoming } })
	local record = new_inventory_record(config.maximum_inventory_items - 1)
	local ok, reason, _, _, projected_count = transfer_rules.validate(record, transaction, left_user_id)
	expect(ok, reason or "valid boundary transfer was rejected")
	expect_equal(projected_count, config.maximum_inventory_items, "boundary projection was incorrect")
end

