local function transaction_schema_migrates_partial_legacy_commit()
	local legacy = new_transaction({ state = "committing" })
	legacy.schema_version = 2
	legacy.protocol_revision = 1
	legacy.coordinator = nil
	legacy.progress.applied[tostring(left_user_id)] = true
	local normalized, reason = schema.normalize_transaction(legacy, legacy.id)
	expect(normalized ~= nil, reason or "legacy committing transaction was rejected")
	local model, ops = new_protocol_model({
		transaction = normalized,
		initially_applied_user_ids = { left_user_id },
	})
	local ok, result = protocol.recover(model.transaction, ops)
	expect(ok, tostring(result))
	expect_equal(model.transaction.state, "completed", "legacy partial commit did not roll forward")
	expect_equal(model.application_effect_counts[tostring(left_user_id)], 1, "legacy applied side duplicated")
	expect_equal(model.application_effect_counts[tostring(right_user_id)], 1, "legacy missing side was not applied")
	expect_no_calls(model.rollback_calls, "legacy committing transaction rolled back")
end

local function mutation_schema_accepts_durable_operation()
	local mutation_id = "mut_00000000000000000000000000000000"
	local item = new_item("item_00000000000000000000000000000004")
	local operation = {
		schema_version = config.mutation_schema_version,
		id = mutation_id,
		user_id = left_user_id,
		kind = "grant_item",
		payload = { item = item, generated_created_at = true },
		result = item.id,
		status = "started",
		created_at = 10,
		updated_at = 10,
	}
	local normalized, reason = schema.normalize_mutation_operation(operation, mutation_id)
	expect(normalized ~= nil, reason or "valid mutation operation was rejected")
	expect_equal(normalized.result, item.id, "mutation result changed")
	local retry_item = new_item(item.id)
	retry_item.created_at = item.created_at + 1
	local retry = {
		schema_version = config.mutation_schema_version,
		id = mutation_id,
		user_id = left_user_id,
		kind = "grant_item",
		payload = { item = retry_item, generated_created_at = true },
		result = retry_item.id,
		status = "started",
		created_at = 11,
		updated_at = 11,
	}
	expect(
		schema.mutation_operations_match(operation, retry),
		"generated grant timestamp made an exact retry conflict"
	)
	retry.payload.item.name = "different item"
	expect(not schema.mutation_operations_match(operation, retry), "different mutation payload was accepted")
end

