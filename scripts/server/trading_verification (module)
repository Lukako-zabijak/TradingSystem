local function valid_offer_request(): any
	return {
		version = config.protocol_version,
		session = "session_00000000000000000000000000000000",
		sequence = 1,
		request_id = "request_00000000",
		action = "set_offer",
		payload = {
			trade_id = transaction_id,
			expected_revision = 0,
			item_ids = {
				"item_00000000000000000000000000000002",
				"item_00000000000000000000000000000001",
			},
		},
	}
end

local function expect_request_rejected(request: any, expected_reason: string)
	local normalized, reason = schema.validate_request(request)
	expect(normalized == nil, "invalid request was accepted")
	expect_equal(reason, expected_reason, "request returned the wrong validation error")
end

local function request_contract_accepts_and_sorts_offer()
	local request = valid_offer_request()
	local normalized, reason = schema.validate_request(request)
	expect(normalized ~= nil, reason or "valid offer was rejected")
	expect(
		normalized.payload.item_ids[1] < normalized.payload.item_ids[2],
		"normalized offer order was not deterministic"
	)
	expect(
		request.payload.item_ids[1] > request.payload.item_ids[2],
		"request validation mutated the caller's item array"
	)
end

local function request_contract_rejects_unknown_fields()
	local envelope = valid_offer_request()
	envelope.exploit = true
	expect_request_rejected(envelope, "invalid_envelope")

	local payload = valid_offer_request()
	payload.payload.exploit = true
	expect_request_rejected(payload, "invalid_payload")
end

local function request_contract_rejects_unsafe_numbers()
	local unsafe_sequence = valid_offer_request()
	unsafe_sequence.sequence = math.huge
	expect_request_rejected(unsafe_sequence, "invalid_sequence")

	local unsafe_revision = valid_offer_request()
	unsafe_revision.payload.expected_revision = 9007199254740992
	expect_request_rejected(unsafe_revision, "invalid_offer")

	local fractional_revision = valid_offer_request()
	fractional_revision.payload.expected_revision = 0.5
	expect_request_rejected(fractional_revision, "invalid_offer")
end

local function request_contract_rejects_malformed_item_arrays()
	local duplicate = valid_offer_request()
	duplicate.payload.item_ids[2] = duplicate.payload.item_ids[1]
	expect_request_rejected(duplicate, "invalid_item_ids")

	local sparse = valid_offer_request()
	sparse.payload.item_ids = {
		[1] = "item_00000000000000000000000000000001",
		[3] = "item_00000000000000000000000000000002",
	}
	expect_request_rejected(sparse, "invalid_item_ids")

	local keyed = valid_offer_request()
	keyed.payload.item_ids = { item = "item_00000000000000000000000000000001" }
	expect_request_rejected(keyed, "invalid_item_ids")
end

local function request_contract_enforces_bootstrap_shape()
	local valid = {
		version = config.protocol_version,
		session = "bootstrap_session",
		sequence = 0,
