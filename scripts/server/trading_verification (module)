function verification.run_all()
	local report: any = {
		passed = true,
		passed_count = 0,
		failed_count = 0,
		tests = {},
		started_at = os.time(),
		finished_at = 0,
	}
	for _, test_case in ipairs(test_cases) do
		local started_at = os.clock()
		local ok, test_error = pcall(function()
			test_case.run()
		end)
		local error_message: string? = nil
		if not ok then
			error_message = tostring(test_error)
		end
		table.insert(report.tests, {
			name = test_case.name,
			passed = ok,
			error = error_message,
			duration_seconds = os.clock() - started_at,
		})
		if ok then
			report.passed_count += 1
		else
			report.passed = false
			report.failed_count += 1
		end
	end
	report.finished_at = os.time()
	verification.last_report = report
	return report.passed, report
end

function verification.run_lease_load_test(player_count: any, budget: any, duration_seconds: any): (boolean, any)
	if
		type(player_count) ~= "number"
		or player_count % 1 ~= 0
		or player_count < 1
		or player_count > 500
		or type(budget) ~= "number"
		or budget % 1 ~= 0
		or budget < 0
		or budget > 1000
		or type(duration_seconds) ~= "number"
		or duration_seconds % 1 ~= 0
		or duration_seconds < 60
		or duration_seconds > 3600
	then
		return false, "invalid_load_test_parameters"
	end

	local refreshes_per_player = math.ceil(duration_seconds / config.lease_refresh_seconds)
	local required_updates = player_count * refreshes_per_player
	local available_updates = math.floor(budget * duration_seconds / 60)
	return true, {
		players = player_count,
		duration_seconds = duration_seconds,
		required_updates = required_updates,
		available_updates = available_updates,
		updates_per_minute = budget,
		budget_sufficient = available_updates >= required_updates,
	}
end

return verification
