--!strict

local data_store_service = game:GetService("DataStoreService")
local messaging_service = game:GetService("MessagingService")

local config = require(script.Parent.Parent.shared:WaitForChild("trading_config (module)"))
local utility = require(script.Parent.Parent.shared:WaitForChild("trading_utility (module)"))

local observability = {}
observability.__index = observability

function observability.new(gateway: any, changed_event: BindableEvent)
	local self = setmetatable({}, observability)
	self.gateway = gateway
	self.changed_event = changed_event
	self.alert_store = data_store_service:GetDataStore(config.alert_store_name)
	self.audit_store = data_store_service:GetDataStore(config.audit_store_name)
	self.alert_dedupe = {}
	self.recent_alerts = {}
	self.alert_worker_count = 0
	self.audit_worker_count = 0
	self.metrics = {
		started_at = os.time(),
		alerts_emitted = 0,
		commits_started = 0,
		commits_completed = 0,
		commits_recovered = 0,
		commits_failed = 0,
		remote_rejections = 0,
		telemetry_dropped = 0,
	}
	return self
end

function observability:emit_alert(code: string, severity: string, context: any, dedupe_key: string?)
	local now = os.time()
	local key = dedupe_key or code
	local sample_seconds = code == "remote_request_rejected" and config.security_alert_sample_seconds or 30
	if self.alert_dedupe[key] and now - self.alert_dedupe[key] < sample_seconds then
		return
	end
	self.alert_dedupe[key] = now
	local dedupe_count = 0
	for dedupe_key, timestamp in pairs(self.alert_dedupe) do
		dedupe_count += 1
		if now - timestamp > config.security_alert_sample_seconds * 2 then
			self.alert_dedupe[dedupe_key] = nil
		end
	end
	if dedupe_count > 512 then
		table.clear(self.alert_dedupe)
		self.alert_dedupe[key] = now
	end

	local alert = {
		id = utility.new_id("alert_"),
		code = code,
		severity = severity,
		context = utility.deep_copy(context),
		server_id = game.JobId,
		created_at = now,
	}
	self.metrics.alerts_emitted += 1
	table.insert(self.recent_alerts, utility.deep_copy(alert))
	while #self.recent_alerts > 100 do
		table.remove(self.recent_alerts, 1)
	end
	self.changed_event:Fire("alert", utility.deep_copy(alert))
	if self.alert_worker_count >= config.maximum_alert_workers then
		self.metrics.telemetry_dropped += 1
		return
	end
	self.alert_worker_count += 1

	task.spawn(function()
		local packed = table.pack(xpcall(function()
			local ok = self.gateway:update(self.alert_store, "recent", function(current)
				local alerts = type(current) == "table" and current or {}
				for _, existing in ipairs(alerts) do
					if existing.id == alert.id then
						return alerts
					end
				end
				table.insert(alerts, alert)
				while #alerts > 100 do
					table.remove(alerts, 1)
				end
				return alerts
			end)
			if not ok then
				warn(string.format("[trading/alert] persistence failed code=%s", code))
			end
			pcall(messaging_service.PublishAsync, messaging_service, config.alert_topic, alert)
		end, debug.traceback))
		self.alert_worker_count = math.max(0, self.alert_worker_count - 1)
		if not packed[1] then
			warn(string.format("[trading/alert] worker failed code=%s", code))
		end
	end)
end

function observability:get_durable_alerts()
	local ok, alerts_or_error = self.gateway:get(self.alert_store, "recent")
	if not ok then
		return false, alerts_or_error
	end
	if type(alerts_or_error) ~= "table" then
		return true, {}
	end
	return true, utility.deep_copy(alerts_or_error)
end

function observability:append_audit(transaction_id: string, event_name: string, details: any)
	if self.audit_worker_count >= config.maximum_audit_workers then
		self.metrics.telemetry_dropped += 1
		return
	end
	local event_id = utility.new_id("event_")
	local key = "audit_" .. transaction_id
	self.audit_worker_count += 1
	task.spawn(function()
		local packed = table.pack(xpcall(function()
			local ok = self.gateway:update(self.audit_store, key, function(current)
				local record = type(current) == "table" and current or { events = {} }
				if type(record.events) ~= "table" then
					record = { events = {} }
				end
				for _, event in ipairs(record.events) do
					if event.id == event_id then
						return record
					end
				end
				table.insert(record.events, {
					id = event_id,
					name = event_name,
					details = utility.deep_copy(details),
					created_at = os.time(),
				})
				while #record.events > 64 do
					table.remove(record.events, 1)
				end
				return record
			end)
			if not ok then
				self:emit_alert("audit_write_failed", "warning", {
					transaction_id = transaction_id,
					event_name = event_name,
				}, "audit:" .. transaction_id)
			end
		end, debug.traceback))
		self.audit_worker_count = math.max(0, self.audit_worker_count - 1)
		if not packed[1] then
			warn(string.format("[trading/audit] worker failed transaction=%s", transaction_id))
		end
	end)
end

function observability:snapshot()
	return {
		service = table.clone(self.metrics),
		data_store = self.gateway:snapshot_metrics(),
	}
end

return observability
